rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================
    // Helper Functions
    // ============================================

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Get user role (safe — returns '' if profile doesn't exist yet)
    function getUserRole() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null ? userDoc.data.role : '';
    }

    // Role hierarchy checks (from highest to lowest privilege)
    // superadmin > admin > maintainer > editor > user

    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'superadmin';
    }

    function isAdminOrAbove() {
      let role = getUserRole();
      return isAuthenticated() && (role == 'superadmin' || role == 'admin');
    }

    function isMaintainerOrAbove() {
      let role = getUserRole();
      return isAuthenticated() && (role == 'superadmin' || role == 'admin' || role == 'maintainer');
    }

    function isEditorOrAbove() {
      let role = getUserRole();
      return isAuthenticated() && (role == 'superadmin' || role == 'admin' || role == 'maintainer' || role == 'editor');
    }

    // ============================================
    // Users Collection
    // ============================================
    match /users/{userId} {
      // All authenticated users can read user profiles
      allow read: if isAuthenticated();

      // Create: Self-registration (own doc, role must be 'user') or superadmin
      allow create: if (isAuthenticated() && request.auth.uid == userId && request.resource.data.role == 'user')
        || isSuperAdmin();

      // Delete: Superadmin only
      allow delete: if isSuperAdmin();

      // Update: Superadmin (full), Admin (can't change superadmin), or own profile (can't change role)
      allow update: if isSuperAdmin()
        || (isAdminOrAbove() && resource.data.role != 'superadmin' && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
        || (isAuthenticated() && request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'email']));
    }

    // ============================================
    // Patients Collection
    // Role: Read (all), Create/Update (editor+), Delete (admin+)
    // ============================================
    match /patients/{patientId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditorOrAbove();
      allow delete: if isAdminOrAbove();
    }

    // ============================================
    // Tests Collection
    // Role: Read (all), Write (maintainer+)
    // ============================================
    match /tests/{testId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isMaintainerOrAbove();
    }

    // ============================================
    // Checkups Collection
    // Role: Read (all), Create/Update (editor+), Delete (admin+)
    // ============================================
    match /checkups/{checkupId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditorOrAbove();
      allow delete: if isMaintainerOrAbove();
    }

    // ============================================
    // Medicines Collection
    // Role: Read (all), Write (maintainer+)
    // ============================================
    match /medicines/{medicineId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isMaintainerOrAbove();
    }

    // ============================================
    // Role Change Requests Collection
    // ============================================
    match /userChangeRequests/{requestId} {
      // Admin+ can read all requests
      allow read: if isAdminOrAbove();
      // Any authenticated user can create a request for themselves
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Superadmin can approve/reject (update/delete)
      allow update, delete: if isSuperAdmin();
    }

    // ============================================
    // User Activities Collection (Audit Trail)
    // ============================================
    match /userActivities/{activityId} {
      // All authenticated users can create activity logs
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Only superadmin can read/delete activities
      allow read, delete: if isSuperAdmin();
      // No one can update activities (immutable audit trail)
      allow update: if false;
    }

    // ============================================
    // Settings Collection
    // ============================================
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isEditorOrAbove();
    }

    // ============================================
    // Notifications Collection
    // ============================================
    match /notifications/{notificationId} {
      // Users can read their own notifications OR system-wide notifications (recipientId == 'all')
      allow read: if isAuthenticated()
        && (resource.data.recipientId == request.auth.uid || resource.data.recipientId == 'all');
      // Authenticated users can create notifications
      allow create: if isAuthenticated();
      // Users can update (mark as read) their own OR system notifications
      allow update: if isAuthenticated()
        && (resource.data.recipientId == request.auth.uid || resource.data.recipientId == 'all');
      // No delete - notifications are archived, not deleted
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // Appointments Collection
    // ============================================
    match /appointments/{appointmentId} {
      // Users can read their own appointments, editor+ can read all (pending queue)
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isEditorOrAbove());
      // Any authenticated user can create an appointment for themselves
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Editor+ can update (approve/reject), users can edit their own pending ones
      allow update: if isEditorOrAbove()
        || (isAuthenticated() && resource.data.userId == request.auth.uid && resource.data.status == 'pending');
      // Users can delete their own pending appointments, superadmin can delete any
      allow delete: if isSuperAdmin()
        || (isAuthenticated() && resource.data.userId == request.auth.uid && resource.data.status == 'pending');
    }

    // ============================================
    // Deny all other access (catch-all)
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
